{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LittleOPA QR",
  "version": "1.0.0",
  "identifier": "de.phillipxh.littleopa-qr",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LittleOPA QR",
        "width": 1360,
        "height": 920,
        "minWidth": 980,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
